# ─── Required ─────────────────────────────────────────────────
# Supabase PostgreSQL connection (pooled — for serverless)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:6543/postgres?pgbouncer=true"
# Supabase PostgreSQL direct connection (for migrations)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# Your production domain
BASE_URL="https://yourdomain.com"

# Admin login password
ADMIN_TOKEN="change-me-to-something-secure"

# Session cookie signing secret (generate: openssl rand -base64 32)
SESSION_SECRET="change-me-to-a-random-string"

# Vercel Blob storage token (auto-set by Vercel if you add Blob store)
BLOB_READ_WRITE_TOKEN=""

# ─── Optional ────────────────────────────────────────────────
# Resend for transactional emails (emails → console.log if blank)
# Sign up at resend.com, verify devashishsingh.com domain, then paste key here
RESEND_API_KEY="re_..."
SENDER_EMAIL="hello@devashishsingh.com"
SENDER_NAME="Devashish"
CONTACT_TARGET_EMAIL="hello@devashishsingh.com"

# Booking calendar link
CALENDAR_URL=""

# ─── Blog Engine AI (optional) ───────────────────────────────
# Used by lib/blog-engine/ai.ts to rewrite posts in v2 format.
# Without these, the engine falls back to a deterministic lift (still works,
# just no LLM rewrite). Any OpenAI-compatible endpoint works.
#
# Free option — Groq (recommended): https://console.groq.com/keys
#   OPENAI_API_KEY=gsk_...
#   OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   OPENAI_MODEL=llama-3.3-70b-versatile
#
# Free option — Google Gemini: https://aistudio.google.com/apikey
#   OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   OPENAI_MODEL=gemini-2.0-flash
#
# Paid — OpenAI (default if BASE_URL omitted):
#   OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
OPENAI_MODEL=""
